PORT=3001
JWT_SECRET=sua_chave_secreta_aqui
FRONTEND_URL=http://localhost:5173

# Banco de dados — em dev usa SQLite automaticamente. Em prod, setar a URL do Postgres (Neon, Supabase, etc.)
DATABASE_URL=

# IA (Groq — chat do AIAssistant)
GROQ_API_KEY=

# Alertas via WhatsApp (CallMeBot)
ALERT_PHONE_1=
ALERT_APIKEY_1=
ALERT_PHONE_2=
ALERT_APIKEY_2=

# Segredo para autenticar requisições do cron job
CRON_SECRET=

# Segredo para proteger /api/admin/* (header X-Admin-Key).
# Frontend (ZombieCleanup) lê de VITE_ADMIN_KEY no build do Vite.
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=

# Meta / Facebook — Marketing API (https://developers.facebook.com)
FB_APP_ID=
FB_APP_SECRET=
# Conta de anúncios padrão (opcional — sistema auto-descobre)
FB_AD_ACCOUNT_ID=
# Token p/ validar webhook do Meta (qualquer string aleatória)
FB_WEBHOOK_VERIFY_TOKEN=

# Criptografia de access_tokens no DB (32 bytes base64)
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY=

# Google Ads (opcional — integração ainda é stub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=
