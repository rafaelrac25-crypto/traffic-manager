{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    },
    {
      "src": "backend/src/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["frontend/dist/**"],
        "maxDuration": 300
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/src/index.js" },
    { "src": "/(.*)", "dest": "backend/src/index.js" }
  ]
}
